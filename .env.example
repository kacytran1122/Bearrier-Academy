# B(e)arrier Academy — environment variables
# Copy to .env.local and fill in. The app runs WITHOUT these (the AI helper
# falls back to friendly canned lines and the map uses the built-in preview),
# so you only need them to turn on the real services.

# Claude — powers Ranger Bear, the Helper, and Coach Owl (server-side only).
ANTHROPIC_API_KEY=

# Google Maps Platform — real satellite map, geocoding, places, aerial flyover.
# Browser key is website-restricted and safe to expose; server key stays secret.
# NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# GOOGLE_MAPS_SERVER_KEY=

# what3words — turns a spot into three simple words, and back (server-side only).
# WHAT3WORDS_API_KEY=

# Deepgram — voice input (speech to text) and read-aloud (text to speech).
# DEEPGRAM_API_KEY=
